{
  "info": {
    "name": "ArtistKashi API",
    "description": "Complete API collection for ArtistKashi Backend - FastAPI endpoints for testing",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Basic Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/health",
              "host": ["{{BASE_URL}}"],
              "path": ["health"]
            },
            "description": "Check if service is healthy"
          },
          "response": []
        },
        {
          "name": "Detailed Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/health/detailed",
              "host": ["{{BASE_URL}}"],
              "path": ["health", "detailed"]
            },
            "description": "Get detailed health status of all services"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"SecurePass123!\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/register",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "register"]
            },
            "description": "Register a new user account"
          },
          "response": []
        },
        {
          "name": "Login (JWT)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "user@example.com"
                },
                {
                  "key": "password",
                  "value": "SecurePass123!"
                }
              ]
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/jwt/login",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "jwt", "login"]
            },
            "description": "Login and receive JWT token"
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ACCESS_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/auth/jwt/logout",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "jwt", "logout"]
            },
            "description": "Logout and invalidate token"
          },
          "response": []
        },
        {
          "name": "Verify Email",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"verification_token_here\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/verify",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "verify"]
            },
            "description": "Verify user email"
          },
          "response": []
        },
        {
          "name": "Request Password Reset",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/forgot-password",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "forgot-password"]
            },
            "description": "Request password reset"
          },
          "response": []
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"reset_token_here\",\n  \"password\": \"NewPassword123!\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/reset-password",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "reset-password"]
            },
            "description": "Reset password with token"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Current Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ACCESS_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/profiles/me",
              "host": ["{{BASE_URL}}"],
              "path": ["profiles", "me"]
            },
            "description": "Get authenticated user's profile"
          },
          "response": []
        },
        {
          "name": "List All Profiles",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/profiles?q=",
              "host": ["{{BASE_URL}}"],
              "path": ["profiles"],
              "query": [
                {
                  "key": "q",
                  "value": "",
                  "description": "Search by email (optional)"
                }
              ]
            },
            "description": "List all public user profiles"
          },
          "response": []
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ACCESS_TOKEN}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newemail@example.com\",\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/users/me",
              "host": ["{{BASE_URL}}"],
              "path": ["users", "me"]
            },
            "description": "Update current user profile"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Addresses",
      "item": [
        {
          "name": "Create Address",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ACCESS_TOKEN}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"street_address\": \"123 Main St\",\n  \"city\": \"New York\",\n  \"state\": \"NY\",\n  \"postal_code\": \"10001\",\n  \"country\": \"USA\",\n  \"is_default\": true\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/addresses",
              "host": ["{{BASE_URL}}"],
              "path": ["addresses"]
            },
            "description": "Create a new address for current user"
          },
          "response": []
        },
        {
          "name": "List User Addresses",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ACCESS_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/addresses",
              "host": ["{{BASE_URL}}"],
              "path": ["addresses"]
            },
            "description": "Get all addresses for current user"
          },
          "response": []
        },
        {
          "name": "Delete Address",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ACCESS_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/addresses/{{ADDRESS_ID}}",
              "host": ["{{BASE_URL}}"],
              "path": ["addresses", "{{ADDRESS_ID}}"]
            },
            "description": "Delete an address"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "List Public Reviews",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/reviews?skip=0&limit=20&review_type=&entity_id=",
              "host": ["{{BASE_URL}}"],
              "path": ["reviews"],
              "query": [
                {
                  "key": "skip",
                  "value": "0"
                },
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "review_type",
                  "value": "",
                  "description": "Filter by review type (optional)"
                },
                {
                  "key": "entity_id",
                  "value": "",
                  "description": "Filter by entity ID (optional)"
                }
              ]
            },
            "description": "Get approved reviews (public endpoint)"
          },
          "response": []
        },
        {
          "name": "Create Review",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ACCESS_TOKEN}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"product\",\n  \"entity_id\": 1,\n  \"rating\": 5,\n  \"comment\": \"Great product! Highly recommended.\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/reviews",
              "host": ["{{BASE_URL}}"],
              "path": ["reviews"]
            },
            "description": "Create a new review (requires login)"
          },
          "response": []
        },
        {
          "name": "Get My Reviews",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ACCESS_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/reviews/user/my-reviews",
              "host": ["{{BASE_URL}}"],
              "path": ["reviews", "user", "my-reviews"]
            },
            "description": "Get current user's reviews"
          },
          "response": []
        }
      ]
    },
