# ==================== DATABASE ====================
# Local database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/mydatabase

# Test database
TEST_DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5433/testdatabase

# ==================== SECURITY ====================
# Secret keys
ACCESS_SECRET_KEY=your_access_secret_key_change_this_in_production
RESET_PASSWORD_SECRET_KEY=your_reset_password_secret_key_change_this_in_production
VERIFICATION_SECRET_KEY=your_verification_secret_key_change_this_in_production

# Admin bootstrap (optional one-off command)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeThisPassword123!
ADMIN_FULL_NAME=Site Admin
ADMIN_UPDATE_PASSWORD=false

# ==================== CACHE & QUEUE (Redis) ====================
# Redis configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ==================== EMAIL ====================
# Email configuration (using Mailhog for local development)
MAIL_USERNAME=test
MAIL_PASSWORD=test
MAIL_FROM=test@test.com
MAIL_PORT=1025
MAIL_SERVER=localhost
MAIL_STARTTLS=False
MAIL_SSL_TLS=False
USE_CREDENTIALS=False
VALIDATE_CERTS=False

# ==================== FRONTEND ====================
# Frontend URL
FRONTEND_URL=http://localhost:3000

# ==================== CORS ====================
# CORS Origins (Allow all origins for development; adjust this to restrict origins in production deployments)
CORS_ORIGINS=["*"]

# ==================== OPENAPI ====================
# OpenAPI generated file output path
OPENAPI_OUTPUT_FILE=../nextjs-frontend/openapi.json

# OpenAPI docs URL (Uncomment the line below to disable the /docs and openapi.json urls)
# OPENAPI_URL=
