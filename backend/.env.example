# ==================== APPLICATION ====================

ENVIRONMENT=development
DEBUG=true

API_V1_PREFIX=/api

# ==================== DATABASE ====================

DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/mydatabase
TEST_DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5433/testdatabase

# ==================== SECURITY ====================

ACCESS_SECRET_KEY=replace_with_secure_access_secret
RESET_PASSWORD_SECRET_KEY=replace_with_secure_reset_secret
VERIFICATION_SECRET_KEY=replace_with_secure_verification_secret

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ==================== ADMIN ====================

ADMIN_EMAIL=[admin@example.com](mailto:admin@example.com)
ADMIN_PASSWORD=ChangeThisPassword123!
ADMIN_FULL_NAME=Site Admin
ADMIN_UPDATE_PASSWORD=false

# ==================== REDIS ====================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ==================== EMAIL ====================

MAIL_USERNAME=test
MAIL_PASSWORD=test
MAIL_FROM=[test@test.com](mailto:test@test.com)
MAIL_PORT=1025
MAIL_SERVER=localhost

MAIL_STARTTLS=False
MAIL_SSL_TLS=False
USE_CREDENTIALS=False
VALIDATE_CERTS=False

# ==================== FRONTEND ====================

FRONTEND_URL=http://localhost:3000

# ==================== CORS ====================

CORS_ORIGINS=["*"]

# ==================== OPENAPI ====================

ENABLE_DOCS=true

OPENAPI_URL=/openapi.json
OPENAPI_OUTPUT_FILE=./shared-data/openapi.json
